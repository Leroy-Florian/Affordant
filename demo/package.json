{
  "name": "@affordant/demo",
  "version": "0.0.0",
  "private": true,
  "description": "End-to-end demo: Express and pure-Node backends emitting the Affordant envelope, consumed over HTTP by a vanilla JS front and a React front.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n express,node,web -c green,cyan,magenta \"npm:dev:express\" \"npm:dev:node\" \"npm:web\"",
    "start": "npm run dev",
    "dev:express": "tsx src/start.ts express 8787",
    "dev:node": "tsx src/start.ts node 8788",
    "web": "vite",
    "build:web": "vite build",
    "preview": "vite preview --port 4173 --strictPort",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@affordant/express": "*",
    "@affordant/react": "*",
    "@affordant/server": "*",
    "affordant": "*",
    "express": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.0",
    "vite": "^6.0.0"
  }
}
