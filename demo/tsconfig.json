{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "noEmit": true,
    "paths": {
      "affordant": ["../packages/client/src/index.ts"],
      "@affordant/contract": ["../packages/contract/src/index.ts"],
      "@affordant/server": ["../packages/server/src/index.ts"],
      "@affordant/express": ["../packages/express/src/index.ts"],
      "@affordant/react": ["../packages/react/src/index.ts"]
    }
  },
  "include": ["src", "tests"]
}
