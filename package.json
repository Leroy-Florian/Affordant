{
  "name": "affordant-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Affordance-first hypermedia (HATEOAS) toolkit: shared wire contract, vanilla client, server-side envelope builder, and framework adapters.",
  "license": "MIT",
  "author": "Florian Leroy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leroy-Florian/Affordant.git"
  },
  "homepage": "https://leroy-florian.github.io/Affordant/",
  "bugs": "https://github.com/Leroy-Florian/Affordant/issues",
  "type": "module",
  "workspaces": [
    "packages/contract",
    "packages/client",
    "packages/react",
    "packages/vue",
    "packages/server",
    "packages/express",
    "demo"
  ],
  "scripts": {
    "build": "npm run build -w @affordant/contract && npm run build -w affordant && npm run build -w @affordant/react && npm run build -w @affordant/server && npm run build -w @affordant/express && npm run build -w @affordant/vue",
    "typecheck": "npm run build && npm run typecheck --workspaces --if-present",
    "pretest": "npm run build",
    "test": "vitest run",
    "demo": "npm start -w @affordant/demo",
    "demo:web": "npm run web -w @affordant/demo",
    "e2e": "npm run e2e -w @affordant/demo",
    "smoke": "node smoke/run.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version && npm install --package-lock-only",
    "release": "npm run build && changeset publish",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^6.0.3",
    "vue": "^3.4.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.8"
  }
}
