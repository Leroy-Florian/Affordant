{
  "name": "@affordant/react",
  "version": "0.3.0",
  "description": "React adapter for Affordant: gate UI on the server's affordances and follow them with hooks. Zero runtime dependencies beyond React.",
  "license": "MIT",
  "author": "Florian Leroy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leroy-Florian/Affordant.git",
    "directory": "packages/react"
  },
  "homepage": "https://leroy-florian.github.io/Affordant/",
  "bugs": "https://github.com/Leroy-Florian/Affordant/issues",
  "keywords": [
    "hateoas",
    "hypermedia",
    "affordance",
    "react",
    "hooks"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "affordant": "^0.2.0",
    "@affordant/contract": "^0.2.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  }
}
