{
  "name": "@affordant/effect",
  "version": "0.1.0",
  "description": "Effect-flavoured invoker for Affordant: follow the server's affordances as an Effect with a typed error channel and fiber-interruptible requests.",
  "license": "MIT",
  "author": "Florian Leroy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Leroy-Florian/Affordant.git",
    "directory": "packages/effect"
  },
  "homepage": "https://leroy-florian.github.io/Affordant/",
  "bugs": "https://github.com/Leroy-Florian/Affordant/issues",
  "keywords": ["hateoas", "hypermedia", "affordance", "effect", "api-client"],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "dependencies": {
    "affordant": "^0.1.0",
    "@affordant/contract": "^0.1.0"
  },
  "peerDependencies": {
    "effect": "^3.21.0"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  }
}
